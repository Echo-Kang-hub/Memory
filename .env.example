# 复制此文件为 .env 并填入真实值

# Chat-LLM 服务配置
# 对话 LLM 的 API Key（支持任意兼容 OpenAI 接口的服务）
CHAT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CHAT_BASE_URL 可替换为其他兼容 OpenAI 接口的服务地址
# OpenAI（默认）:   https://api.openai.com/v1
# OpenRouter:       https://openrouter.ai/api/v1
# DeepSeek:         https://api.deepseek.com/v1
# 本地 Ollama:      http://localhost:11434/v1
CHAT_BASE_URL=https://api.openai.com/v1

# 对话模型
CHATMODEL=gpt-4o-mini




# ── Embedding / 向量记忆配置 ───────────────────────────────────────────
# EMBED_TYPE 决定使用哪种 embedding 方案，三选一：local | ollama | api
EMBED_TYPE=local

# ── 模式 A: local（纯本地，无需联网，首次运行自动从 HuggingFace 下载模型）──
# 模型名称（HuggingFace model id）
EMBED_LOCAL_MODEL=Qwen/Qwen3-Embedding-0.6B
# 推理设备：cpu（默认）/ cuda（NVIDIA GPU）/ mps（Apple Silicon）
EMBED_LOCAL_DEVICE=cpu

# ── 模式 B: ollama（需本地安装并运行 Ollama）─────────────────────────────
# 先执行: ollama pull qwen3-embedding
EMBED_OLLAMA_MODEL=qwen3-embedding
EMBED_OLLAMA_URL=http://localhost:11434

# ── 模式 C: api（兼容 OpenAI 接口的远程 embedding 服务）─────────────────
# embedding 专用 API Key（与对话模型同服务时可填相同值）
EMBED_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# embedding 服务地址（默认 OpenAI，可换其他兼容服务）
EMBED_API_BASE=https://api.openai.com/v1
# 模型名，OpenAI 可选: text-embedding-3-small / text-embedding-3-large / text-embedding-ada-002
EMBED_MODEL=text-embedding-3-small

# ── ChromaDB 向量数据库本地持久化路径（三种模式共用）────────────────────────
VECTOR_DB_PATH=./data/chroma

# ── 系统提示词 ─────────────────────────────────────────────────────
SYSTEM_PROMPT=你是一个具备记忆能力的智能助手，请结合已知记忆给出个性化回复。

# ── 记忆整理 LLM（Consolidator）────────────────────────────────────
# CONSOLIDATE_TYPE 决定后台整理线程使用哪种 LLM，三选一：api | ollama | local
CONSOLIDATE_TYPE=api

# ── 模式 A: api（默认，兼容 OpenAI 接口，可配置独立于对话模型的服务）────────
# 留空则分别复用 CHAT_API_KEY / CHAT_BASE_URL / CHATMODEL
# CONSOLIDATE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CONSOLIDATE_API_BASE=https://api.openai.com/v1
# CONSOLIDATE_MODEL=gpt-4o-mini

# ── 模式 B: ollama（需本地安装并运行 Ollama，使用原生 ollama 客户端）─────────
# 先执行: ollama pull qwen2.5:7b（或其他支持 JSON 输出的指令模型）
# CONSOLIDATE_OLLAMA_MODEL=qwen2.5:7b
# CONSOLIDATE_OLLAMA_URL=http://localhost:11434

# ── 模式 C: local（直接加载 HuggingFace 模型，无需外部服务，需 transformers）──
# CONSOLIDATE_LOCAL_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# CONSOLIDATE_LOCAL_DEVICE=cpu   # cpu / cuda / mps

# 动态记忆去重阈值（ChromaDB cosine distance，越低越相似，小于此值才触发 LLM 比对）
# MEMORY_DEDUP_THRESHOLD=0.4

# ── Agent Memory 参数 ──────────────────────────────────────────────
SHORT_TERM_LIMIT=10
